<model>
    <mount>//OPNsense/KeaUbnd</mount>
    <version>1.0.0</version>
    <description>Kea Unbound DDNS registration</description>
    <items>
        <general>
            <!-- Master enable switch. When disabled, the daemon does not start
                 and the bootup hook is a no-op. -->
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>

            <!-- UDP port the stub RFC 2136 listener binds to on 127.0.0.1.
                 Must match the destination port configured in kea-dhcp-ddns.
                 Default 53535 is in the Kea port family (kea-ctrl-agent uses
                 53001) and does not conflict with any standard service. -->
            <port type="IntegerField">
                <Default>53535</Default>
                <Required>Y</Required>
                <MinimumValue>1024</MinimumValue>
                <MaximumValue>65535</MaximumValue>
            </port>

            <!-- Sync static reservations from Kea to Unbound during the bulk
                 reconcile (run by the daemon after a Kea/Unbound restart). -->
            <sync_static_reservations type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </sync_static_reservations>

            <!-- Sync active DHCP leases from Kea to Unbound during the bulk
                 reconcile. TTL is set to the remaining lease lifetime. -->
            <sync_dynamic_leases type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </sync_dynamic_leases>

            <!-- Synthesize PTR (reverse) records from forward A/AAAA DDNS updates.
                 When enabled (default), the DDNS listener automatically creates the
                 standard in-addr.arpa / ip6.arpa PTR record for every A/AAAA ADD it
                 receives from kea-dhcp-ddns. This works whether or not a reverse zone
                 is configured in kea-dhcp-ddns.

                 Disable this only if you manage reverse DNS separately (e.g., another
                 authoritative server for in-addr.arpa) and do not want this plugin to
                 write or delete PTR records via the live path. Explicit PTR NCRs from
                 kea-dhcp-ddns (reverse-ddns zone configured) are always applied
                 regardless of this setting. -->
            <synthesize_ptr type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </synthesize_ptr>

            <!-- How to handle a DDNS registration for a hostname that is already
                 registered to a different IP address.
                 last_wins:   existing record is replaced by the new one. Default.
                 allow:       both records coexist in Unbound (round-robin).
                 first_wins:  existing record is kept; the new registrant is rejected.
                              Static reservations are always loaded before dynamic leases,
                              so first_wins naturally protects reservations from being
                              overwritten. Note: first_wins is best-effort on reconcile
                              (ordering is deterministic within a run, not across restarts). -->
            <collision_policy type="OptionField">
                <Required>Y</Required>
                <Default>last_wins</Default>
                <OptionValues>
                    <allow>Allow — both records coexist</allow>
                    <first_wins>First wins — keep existing, reject new registrant</first_wins>
                    <last_wins>Last wins — replace existing with new record (default)</last_wins>
                </OptionValues>
            </collision_policy>

            <!-- After each full reconcile (triggered by a Kea or Unbound restart),
                 sweep Unbound for records no longer backed by any Kea reservation
                 or active lease and remove them. Equivalent to running the auto-clean
                 script immediately after every restart-driven resync. Requires Kea to
                 be reachable during the reconcile. -->
            <clean_on_restart type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </clean_on_restart>

            <!-- Watch Kea DHCP log and listener log for missed updates.
                 On lease release (DHCP4_RELEASE / DHCP6_RELEASE): dispatches
                 local-data-clean.py with purge-ip under the shared lock.
                 On listener SERVFAIL: triggers kea-sync.py with targeted names
                 for the affected hosts so dirty-name drain is not the only
                 recovery path.
                 Runs as a separate daemon started alongside the main listener. -->
            <enable_logwatch type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enable_logwatch>

            <!-- Automatically clean stale DNS records from Unbound.
                 When enabled, the local-data-clean.py script runs periodically
                 to remove stale records (entries in Unbound that don't match
                 any Kea reservation, lease, or OPNsense-managed entry). -->
            <enable_auto_clean type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enable_auto_clean>

            <!-- How often to run the auto-clean job.
                 Only used when enable_auto_clean is enabled.
                 'daily' uses auto_clean_hour as the hour of day (0-23). -->
            <auto_clean_interval type="OptionField">
                <Required>Y</Required>
                <Default>h6</Default>
                <OptionValues>
                    <h1>Every hour</h1>
                    <h3>Every 3 hours</h3>
                    <h6>Every 6 hours</h6>
                    <h12>Every 12 hours</h12>
                    <daily>Daily (at a specific hour)</daily>
                </OptionValues>
            </auto_clean_interval>

            <!-- Hour of day (0–23) for the daily auto-clean run.
                 Only used when auto_clean_interval is 'daily'. -->
            <auto_clean_hour type="IntegerField">
                <Default>0</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>23</MaximumValue>
            </auto_clean_hour>

            <!-- Advanced: maximum number of dirty names held before the next
                 reconcile is a full sync regardless of the names filter.
                 Smaller values reduce targeted-drain scope at higher churn. -->
            <dirty_set_cap type="IntegerField">
                <Default>100</Default>
                <Required>N</Required>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>10000</MaximumValue>
            </dirty_set_cap>

            <!-- Advanced: how many failed reconcile attempts are allowed before
                 the daemon marks itself degraded (alert state) and stops retrying.
                 0 means retry indefinitely. -->
            <max_full_sync_attempts type="IntegerField">
                <Default>5</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>100</MaximumValue>
            </max_full_sync_attempts>

            <!-- Advanced: minutes to wait for Kea/Unbound to become ready before
                 the readiness watchdog terminates the daemon and lets daemon(8)
                 restart it. 0 disables the watchdog (wait forever). -->
            <readiness_watchdog_minutes type="IntegerField">
                <Default>10</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>1440</MaximumValue>
            </readiness_watchdog_minutes>
        </general>
    </items>
</model>
