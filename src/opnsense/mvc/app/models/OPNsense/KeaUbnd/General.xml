<model>
    <mount>//OPNsense/KeaUbnd</mount>
    <version>1.0.1</version>
    <description>Kea Unbound DDNS registration</description>
    <items>
        <general>
            <!-- Master enable switch. When disabled, the daemon does not start
                 and the bootup hook is a no-op. -->
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>

            <!-- UDP port the stub RFC 2136 listener binds to on 127.0.0.1.
                 Must match the destination port configured in kea-dhcp-ddns.
                 Default 53535 is in the Kea port family (kea-ctrl-agent uses
                 53001) and does not conflict with any standard service. -->
            <port type="IntegerField">
                <Default>53535</Default>
                <Required>Y</Required>
                <MinimumValue>1024</MinimumValue>
                <MaximumValue>65535</MaximumValue>
            </port>

            <!-- Synthesize PTR (reverse) records from forward A/AAAA DDNS updates.
                 When enabled (default), the DDNS listener automatically creates the
                 standard in-addr.arpa / ip6.arpa PTR record for every A/AAAA ADD it
                 receives from kea-dhcp-ddns. This works whether or not a reverse zone
                 is configured in kea-dhcp-ddns.

                 Disable this only if you manage reverse DNS separately (e.g., another
                 authoritative server for in-addr.arpa) and do not want this plugin to
                 write or delete PTR records via the live path. Explicit PTR NCRs from
                 kea-dhcp-ddns (reverse-ddns zone configured) are always applied
                 regardless of this setting. -->
            <synthesize_ptr type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </synthesize_ptr>

            <!-- How to handle a DDNS registration for a hostname that is already
                 registered to a different IP address.
                 last_wins:   existing record is replaced by the new one. Default.
                 allow:       both records coexist in Unbound (round-robin).
                 first_wins:  existing record is kept; the new registrant is rejected.
                              Static reservations are always loaded before dynamic leases,
                              so first_wins naturally protects reservations from being
                              overwritten. Note: first_wins is best-effort on reconcile
                              (ordering is deterministic within a run, not across restarts). -->
            <collision_policy type="OptionField">
                <Required>Y</Required>
                <Default>last_wins</Default>
                <OptionValues>
                    <allow>Allow — both records coexist</allow>
                    <first_wins>First wins — keep existing, reject new registrant</first_wins>
                    <last_wins>Last wins — replace existing with new record (default)</last_wins>
                    <none>None — evict all dynamic records on conflict</none>
                </OptionValues>
            </collision_policy>

            <!-- Create disambiguated parallel forward records (magic hostnames) for
                 all hosts involved in a hostname collision, orthogonal to collision_policy.
                 The suffix encodes the hardware identifier type and last 6 chars of the
                 identifier (e.g. laptop-mAABBCC for a MAC-identified host). -->
            <magic_names type="BooleanField">
                <Default>0</Default>
            </magic_names>

            <!-- When magic_names is on, insert -laa- into the magic hostname for devices
                 whose MAC has the locally administered bit set (iOS/Android random MACs).
                 Signals to the administrator that the suffix may not be stable. -->
            <magic_laa_tag type="BooleanField">
                <Default>0</Default>
            </magic_laa_tag>

            <!-- When magic_names is on AND synthesize_ptr is on, write PTR records
                 pointing to the magic FQDN for every dynamic lease IP in a collision
                 group, rather than the bare hostname. When off, PTR behaviour is
                 unchanged from non-magic mode: the collision winner gets PTR to the
                 bare hostname, losers get no PTR. Has no effect if either magic_names
                 or synthesize_ptr is disabled. -->
            <write_magic_ptrs type="BooleanField">
                <Default>0</Default>
            </write_magic_ptrs>

            <!-- After each full reconcile (triggered by a Kea or Unbound restart),
                 sweep Unbound for records no longer backed by any Kea reservation
                 or active lease and remove them. Equivalent to running the auto-clean
                 script immediately after every restart-driven resync. Requires Kea to
                 be reachable during the reconcile. -->
            <clean_stale_records type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </clean_stale_records>

            <!-- Watch Kea DHCP log and listener log for missed updates.
                 Runs as a separate daemon started alongside the main listener.
                 The three sub-options below control which events trigger action.
                 Off by default — the cron sync path covers most deployments. -->
            <enable_logwatch type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enable_logwatch>

            <!-- On DHCP4_RELEASE / DHCP6_RELEASE: purge DNS records for that IP
                 immediately via local-data-clean.py purge-ip.
                 Only used when enable_logwatch is enabled. -->
            <logwatch_on_release type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </logwatch_on_release>

            <!-- On listener SERVFAIL (Unbound unavailable or locked during an
                 update): trigger a targeted kea-sync.py for the affected names
                 as an additional recovery path alongside the dirty-name drain.
                 Only used when enable_logwatch is enabled. -->
            <logwatch_on_servfail type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </logwatch_on_servfail>

            <!-- On a DNS Remove without a subsequent Add within a short grace
                 window: trigger a targeted kea-sync.py for the removed hostname.
                 Catches the LEASE_REUSE gap where kea-dhcp-ddns sends a Remove
                 for an IP that is immediately re-leased to the same client but
                 skips the follow-up Add (lease record looks unchanged to D2).
                 Only used when enable_logwatch is enabled. -->
            <logwatch_on_missed_remove type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </logwatch_on_missed_remove>

            <!-- Run scheduled sync and/or clean jobs via cron.
                 The two sub-options below control what the cron job does.
                 At least one should be enabled when this is on. -->
            <enable_auto_clean type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enable_auto_clean>

            <!-- Run a full Kea → Unbound sync (kea-sync.py) on the cron
                 schedule. Catches drift the live path and logwatcher missed.
                 Only used when enable_auto_clean is enabled. -->
            <cron_run_sync type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </cron_run_sync>

            <!-- Run the stale-record cleaner (local-data-clean.py) on the cron
                 schedule. Removes Unbound records not backed by any active Kea
                 lease, reservation, or Unbound Host Override.
                 Only used when enable_auto_clean is enabled. -->
            <cron_run_clean type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </cron_run_clean>

            <!-- How often to run the auto-clean job.
                 Only used when enable_auto_clean is enabled.
                 'daily' uses auto_clean_hour as the hour of day (0-23). -->
            <auto_clean_interval type="OptionField">
                <Required>Y</Required>
                <Default>h6</Default>
                <OptionValues>
                    <h1>Every hour</h1>
                    <h3>Every 3 hours</h3>
                    <h6>Every 6 hours</h6>
                    <h12>Every 12 hours</h12>
                    <daily>Daily (at a specific hour)</daily>
                </OptionValues>
            </auto_clean_interval>

            <!-- Hour of day (0–23) for the daily auto-clean run.
                 Only used when auto_clean_interval is 'daily'. -->
            <auto_clean_hour type="IntegerField">
                <Default>0</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>23</MaximumValue>
            </auto_clean_hour>

            <!-- Advanced: how many failed reconcile attempts are allowed before
                 the daemon marks itself degraded (alert state) and stops retrying.
                 0 means retry indefinitely. -->
            <max_full_sync_attempts type="IntegerField">
                <Default>5</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>100</MaximumValue>
            </max_full_sync_attempts>

            <!-- Advanced: minutes to wait for Kea/Unbound to become ready before
                 the readiness watchdog terminates the daemon and lets daemon(8)
                 restart it. 0 disables the watchdog (wait forever). -->
            <readiness_watchdog_minutes type="IntegerField">
                <Default>10</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>1440</MaximumValue>
            </readiness_watchdog_minutes>

            <!-- Enable periodic unbound-control fast-reload to reclaim heap memory
                 fragmented by repeated local_data add/remove calls. When enabled,
                 the daemon triggers fast-reload after fast_reload_threshold NCRs.
                 A weekly safety-net cron job can also be enabled below. -->
            <enable_fast_reload type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enable_fast_reload>

            <!-- Advanced: number of live-path NCRs (DNS UPDATE packets that
                 returned NOERROR) before the daemon triggers unbound-control
                 fast-reload. Each NCR typically generates 1-3 unbound-control
                 calls (A record plus optional PTR). Only active when
                 enable_fast_reload is enabled. -->
            <fast_reload_threshold type="IntegerField">
                <Default>5000</Default>
                <Required>N</Required>
                <MinimumValue>100</MinimumValue>
                <MaximumValue>100000</MaximumValue>
            </fast_reload_threshold>

            <!-- Enable a scheduled safety-net cron job that calls
                 unbound-control fast-reload even when the daemon counter has
                 not been reached. Catches the daemon-restart-without-Unbound-
                 restart scenario where the counter resets to zero but Unbound
                 memory continues to accumulate. -->
            <enable_fast_reload_cron type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enable_fast_reload_cron>

            <!-- How often the fast-reload safety-net cron job runs.
                 Only used when enable_fast_reload_cron is enabled. -->
            <fast_reload_cron_days type="OptionField">
                <Required>Y</Required>
                <Default>d7</Default>
                <OptionValues>
                    <d1>Every day</d1>
                    <d3>Every 3 days</d3>
                    <d7>Weekly (every 7 days)</d7>
                    <d14>Every 14 days</d14>
                    <d30>Monthly (every 30 days)</d30>
                </OptionValues>
            </fast_reload_cron_days>

            <!-- Hour of day (0-23) at which the scheduled fast-reload cron job fires.
                 Only used when enable_fast_reload_cron is enabled. -->
            <fast_reload_cron_hour type="IntegerField">
                <Default>3</Default>
                <Required>N</Required>
                <MinimumValue>0</MinimumValue>
                <MaximumValue>23</MaximumValue>
            </fast_reload_cron_hour>
        </general>
    </items>
</model>
