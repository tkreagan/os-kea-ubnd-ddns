<model>
    <mount>//OPNsense/KeaUnbound</mount>
    <version>1.0.0</version>
    <description>Kea Unbound DDNS registration</description>
    <items>
        <general>
            <!-- Master enable switch. When disabled, the daemon does not start
                 and all hooks (kea_sync, unbound_start, bootup) are no-ops. -->
            <enabled type="BooleanField">
                <Default>0</Default>
                <Required>Y</Required>
            </enabled>

            <!-- UDP port the stub RFC 2136 listener binds to on 127.0.0.1.
                 Must match the destination port configured in kea-dhcp-ddns.
                 Default 53535 is in the Kea port family (kea-ctrl-agent uses
                 53001) and does not conflict with any standard service. -->
            <port type="IntegerField">
                <Default>53535</Default>
                <Required>Y</Required>
                <MinimumValue>1024</MinimumValue>
                <MaximumValue>65535</MaximumValue>
            </port>

            <!-- Sync static reservations from Kea to Unbound.
                 When enabled, static reservations from Kea are registered in
                 Unbound's local_data via the reservation-sync.py script, making
                 them available in DNS immediately (before any client connects).
                 reservation-sync.py skips any name already in host_entries.conf,
                 so this is safe regardless of Unbound's "Register DHCP Static
                 Mappings" (regdhcpstatic) setting — the plugin only fills the
                 gap for reservations OPNsense has not itself registered. -->
            <sync_static_reservations type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </sync_static_reservations>

            <!-- Sync active DHCP leases from Kea to Unbound.
                 When enabled, active leases from Kea are registered in
                 Unbound's local_data via the lease-sync.py script. TTL is set
                 to the remaining lease lifetime, so entries automatically expire
                 when leases expire, forcing clients to reconnect and refresh.
                 This is called on Unbound startup (to repopulate after reload)
                 and periodically via cron (to keep entries fresh). -->
            <sync_dynamic_leases type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </sync_dynamic_leases>

            <!-- Remove previous IPs for a hostname when a new lease is
                 registered via DDNS ADD. After each successful A/AAAA
                 registration, query Kea for all IPs that hostname currently
                 holds and remove any extras from Unbound that are no longer
                 backed by an active lease or reservation. Handles the common
                 case where Kea issues a client a new IP without sending a
                 DELETE for the old one. Best-effort: ADD outcome is unaffected
                 regardless of whether cleanup succeeds or Kea is reachable. -->
            <aggressive_cleanup type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </aggressive_cleanup>

            <!-- Synthesize PTR (reverse) records from forward A/AAAA DDNS updates.
                 When enabled (default), the DDNS listener automatically creates the
                 standard in-addr.arpa / ip6.arpa PTR record for every A/AAAA ADD it
                 receives from kea-dhcp-ddns. This works whether or not a reverse zone
                 is configured in kea-dhcp-ddns.

                 Disable this only if you manage reverse DNS separately (e.g., another
                 authoritative server for in-addr.arpa) and do not want this plugin to
                 write or delete PTR records via the live path. Explicit PTR NCRs from
                 kea-dhcp-ddns (reverse-ddns zone configured) are always applied
                 regardless of this setting. -->
            <synthesize_ptr type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </synthesize_ptr>

            <!-- How to handle a DDNS registration for a hostname that is already
                 registered to a different IP address.
                 allow:       both records coexist in Unbound (round-robin). Default.
                 first_wins:  existing record is kept; the new registrant is rejected
                              (YXRRSET returned to kea-dhcp-ddns only when Kea is in a
                              check-with-dhcid or check-exists-with-dhcid mode, i.e. when
                              RFC 2136 prerequisite records are present). Static reservations
                              are always loaded before dynamic leases, so first_wins
                              naturally protects reservations from being overwritten.
                 last_wins:   existing record is replaced by the new one. -->
            <collision_policy type="OptionField">
                <Required>Y</Required>
                <Default>allow</Default>
                <OptionValues>
                    <allow>Allow (both records coexist)</allow>
                    <first_wins>First wins (keep existing, reject new registrant)</first_wins>
                    <last_wins>Last wins (replace existing with new record)</last_wins>
                </OptionValues>
            </collision_policy>

            <!-- Automatically clean stale DNS records from Unbound.
                 When enabled, the local-data-clean.py script runs periodically
                 to remove stale records (entries in Unbound that don't match
                 any Kea reservation, lease, or OPNsense-managed entry). -->
            <enable_auto_clean type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </enable_auto_clean>

            <!-- How often to run the auto-clean job.
                 Only used when enable_auto_clean is enabled. -->
            <auto_clean_interval type="OptionField">
                <Required>Y</Required>
                <Default>h6</Default>
                <OptionValues>
                    <h6>Every 6 hours</h6>
                    <h12>Every 12 hours</h12>
                    <h24>Every 24 hours</h24>
                </OptionValues>
            </auto_clean_interval>
        </general>
    </items>
</model>
