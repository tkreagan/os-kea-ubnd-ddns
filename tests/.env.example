# Copy to tests/.env and fill in before running integration tests.
# .env is gitignored; .env.example is committed.

# ── OPNsense / Kea box ────────────────────────────────────────────────────────
OPNSENSE_HOST=dev-opnsense.plhm.rgn.cm
OPNSENSE_SSH_USER=dev
OPNSENSE_SSH_PASS=dev
OPNSENSE_API_KEY=<your-key-id>
OPNSENSE_API_SECRET=<your-key-secret>

# ── DHCP client box (Debian) ──────────────────────────────────────────────────
DHCPCLIENT_HOST=dev-dhcpclient.plhm.rgn.cm
DHCPCLIENT_SSH_USER=dev
DHCPCLIENT_SSH_PASS=dev
DHCPCLIENT_LAN_IF=ens19

# ── Plugin build tree path on the OPNsense box ────────────────────────────────
PLUGIN_DIR=/usr/plugins/net/kea-unbound
