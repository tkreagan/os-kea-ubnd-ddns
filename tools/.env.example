# os-kea-unbound tools configuration
# Copy to tools/.env and fill in values.
# tools/.env is gitignored.

# ── Chaos monkey: dev boxes ──────────────────────────────────────────────────
DEV_OPNSENSE_HOST=dev-opnsense.plhm.rgn.cm
DEV_OPNSENSE_SSH_USER=dev
DEV_OPNSENSE_SSH_PASS=dev

DEV_DHCPCLIENT_HOST=dev-dhcpclient.plhm.rgn.cm
DEV_DHCPCLIENT_SSH_USER=dev
DEV_DHCPCLIENT_SSH_PASS=dev
DEV_DHCPCLIENT_LAN_IF=ens19          # LAN interface on the client box

# DNS suffix used on the dev network (bare label: "lan", not "lan.")
DEV_DOMAIN=lan

# Kea test IP range — safe if outside your real DHCP pool
TEST_IP_PREFIX=192.168.99.
TEST_SUBNET_ID=                       # leave blank to auto-discover from Kea

# Optional: override the plugin build tree path on dev-opnsense
# PLUGIN_DIR=/usr/plugins/net/kea-unbound

# ── Production monitor: orbison ──────────────────────────────────────────────
PROD_HOST=orbison.plhm.rgn.cm
PROD_SSH_USER=kea-monitor             # dedicated prod user with sudo
PROD_SSH_PASS=<password>

# DNS suffix used in production
PROD_DOMAIN=plhm.rgn.cm

# Where to store hourly snapshots on this Mac
MONITOR_ARCHIVE_DIR=~/.kea-unbound-monitor
