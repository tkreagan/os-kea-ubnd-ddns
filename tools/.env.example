# build_package.sh — SSH connection settings for remote builds.
#
# Copy this file to tools/.env and fill in your values.
# tools/.env is gitignored and will never be committed.
#
# You can also pass these as ordinary environment variables instead of
# using this file:
#
#   OPNSENSE_HOST=my-box.example.com OPNSENSE_SSH_KEY=~/.ssh/id_ed25519 ./build_package.sh
#
# Or point build_package.sh at a different file entirely:
#
#   ./build_package.sh --env-file /path/to/my.env

# Hostname or IP of your OPNsense box.
OPNSENSE_HOST=your-opnsense-box.example.com

# SSH user on that box (needs sudo for pkg(8) and make).
OPNSENSE_SSH_USER=root

# Path to your SSH private key for that box.
OPNSENSE_SSH_KEY=~/.ssh/id_ed25519
